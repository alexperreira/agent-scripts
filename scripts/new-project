#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
new-project — create a new repo under ~/Projects and publish to GitHub

Usage:
  scripts/new-project --name <repo-name> [options]

Required:
  --name, -n            Repository name (recommended: kebab-case)

Options:
  --visibility          private|public (default: private)
  --stack               Free-form tech stack string used to seed AGENTS.md
  --description         Short description for README (optional)
  --projects-dir        Base directory (default: $HOME/Projects)
  --license             mit|none (default: mit)
  --owner               GitHub owner/org (default: alexperreira)
  --no-remote           Skip GitHub remote creation/push (local-only)
  --dry-run             Print actions without writing
  --help, -h            Show this help

Examples:
  scripts/new-project --name my-tool --stack "typescript, node, pnpm" --visibility private
  scripts/new-project -n my-lib --stack "python, uv, pytest" --visibility public
  scripts/new-project -n scratch --no-remote --projects-dir /tmp --dry-run
EOF
}

die() {
  echo "error: $*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

is_kebab_case() {
  [[ "${1}" =~ ^[a-z0-9]+([-.][a-z0-9]+)*$ ]]
}

render_template() {
  # $1 = template path, $2 = output path
  # Replaces {{VAR}} tokens with corresponding env vars.
  local template_path="$1"
  local output_path="$2"

  local sed_expr=()
  sed_expr+=("-e" "s/{{PROJECT_NAME}}/${PROJECT_NAME//\//\\/}/g")
  sed_expr+=("-e" "s/{{DESCRIPTION}}/${DESCRIPTION//\//\\/}/g")
  sed_expr+=("-e" "s/{{TECH_STACK}}/${TECH_STACK//\//\\/}/g")
  sed_expr+=("-e" "s/{{YEAR}}/${YEAR}/g")
  sed_expr+=("-e" "s/{{AUTHOR}}/${AUTHOR//\//\\/}/g")
  sed_expr+=("-e" "s/{{GITHUB_OWNER}}/${GITHUB_OWNER//\//\\/}/g")
  sed_expr+=("-e" "s/{{WEBSITE}}/${WEBSITE//\//\\/}/g")

  sed "${sed_expr[@]}" "$template_path" >"$output_path"
}

should_include_node_section() {
  local s
  s="$(echo "${TECH_STACK}" | tr '[:upper:]' '[:lower:]')"
  [[ "$s" == *"ts"* || "$s" == *"typescript"* || "$s" == *"node"* || "$s" == *"pnpm"* || "$s" == *"npm"* ]]
}

should_include_python_section() {
  local s
  s="$(echo "${TECH_STACK}" | tr '[:upper:]' '[:lower:]')"
  [[ "$s" == *"py"* || "$s" == *"python"* || "$s" == *"pytest"* || "$s" == *"uv"* || "$s" == *"pip"* ]]
}

append_stack_sections() {
  local agents_path="$1"

  {
    echo
    echo "## Repo Quickstart (fill in as you go)"
    echo
    if should_include_node_section; then
      cat <<'EOF'
### Node / TypeScript (suggested)
- Install: `pnpm install` (or `npm install`)
- Lint: `pnpm lint`
- Test: `npm test` or `pnpm test`
- Typecheck: `pnpm typecheck`
- Dev: `pnpm dev`
EOF
      echo
    fi

    if should_include_python_section; then
      cat <<'EOF'
### Python (suggested)
- Create venv: `python -m venv .venv`
- Activate: `source .venv/bin/activate`
- Install: `pip install -r requirements.txt` (or `uv sync` if using uv)
- Lint: `ruff check .` (or your tool)
- Test: `pytest -q`
EOF
      echo
    fi

    cat <<'EOF'
### Notes
- Prefer keeping the repo on the WSL filesystem (not under `/mnt/c`) for performance.
- Update this file with concrete commands once the stack stabilizes.
EOF
  } >>"$agents_path"
}

PROJECT_NAME=""
VISIBILITY="private"
TECH_STACK=""
DESCRIPTION=""
PROJECTS_DIR="${HOME}/Projects"
LICENSE_KIND="mit"
GITHUB_OWNER="alexperreira"
CREATE_REMOTE="true"
DRY_RUN="false"

AUTHOR="Alex Perreira"
WEBSITE="alexhacks.net"
YEAR="$(date +%Y)"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --name|-n)
      PROJECT_NAME="${2:-}"; shift 2 ;;
    --visibility)
      VISIBILITY="${2:-}"; shift 2 ;;
    --stack)
      TECH_STACK="${2:-}"; shift 2 ;;
    --description)
      DESCRIPTION="${2:-}"; shift 2 ;;
    --projects-dir)
      PROJECTS_DIR="${2:-}"; shift 2 ;;
    --license)
      LICENSE_KIND="${2:-}"; shift 2 ;;
    --owner)
      GITHUB_OWNER="${2:-}"; shift 2 ;;
    --no-remote)
      CREATE_REMOTE="false"; shift ;;
    --dry-run)
      DRY_RUN="true"; shift ;;
    --help|-h)
      usage; exit 0 ;;
    *)
      die "unknown argument: $1" ;;
  esac
done

[[ -n "$PROJECT_NAME" ]] || die "--name is required"
is_kebab_case "$PROJECT_NAME" || echo "note: '$PROJECT_NAME' is not kebab-case; continuing anyway." >&2

case "$VISIBILITY" in
  private|public) ;;
  *) die "--visibility must be 'private' or 'public' (got: $VISIBILITY)" ;;
esac

case "$LICENSE_KIND" in
  mit|none) ;;
  *) die "--license must be 'mit' or 'none' (got: $LICENSE_KIND)" ;;
esac

TARGET_DIR="${PROJECTS_DIR}/${PROJECT_NAME}"

echo "Project: ${PROJECT_NAME}"
echo "Dir:     ${TARGET_DIR}"
echo "Remote:  https://github.com/${GITHUB_OWNER}/${PROJECT_NAME}.git"
echo "Public:  ${VISIBILITY}"
echo "Stack:   ${TECH_STACK:-<unspecified>}"
echo "License: ${LICENSE_KIND}"
echo

if [[ "$DRY_RUN" == "true" ]]; then
  echo "[dry-run] Would create directory and files"
  echo "[dry-run] Would init git + initial commit"
  if [[ "$CREATE_REMOTE" == "true" ]]; then
    echo "[dry-run] Would create GitHub repo via gh + push"
  else
    echo "[dry-run] Skipping GitHub remote creation"
  fi
  exit 0
fi

require_cmd git
require_cmd sed
require_cmd date

[[ ! -e "$TARGET_DIR" ]] || die "target already exists: $TARGET_DIR"

mkdir -p "$TARGET_DIR"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
TEMPLATE_DIR="${SCRIPT_DIR}/../templates/empty"

[[ -d "$TEMPLATE_DIR" ]] || die "missing templates: $TEMPLATE_DIR"

mkdir -p "${TARGET_DIR}/docs"

if [[ -z "$DESCRIPTION" ]]; then
  DESCRIPTION="New project: ${PROJECT_NAME}"
fi

render_template "${TEMPLATE_DIR}/README.md.tmpl" "${TARGET_DIR}/README.md"
render_template "${TEMPLATE_DIR}/gitignore.tmpl" "${TARGET_DIR}/.gitignore"
render_template "${TEMPLATE_DIR}/AGENTS.md.tmpl" "${TARGET_DIR}/AGENTS.md"
append_stack_sections "${TARGET_DIR}/AGENTS.md"

if [[ "$LICENSE_KIND" == "mit" ]]; then
  render_template "${TEMPLATE_DIR}/LICENSE-MIT.tmpl" "${TARGET_DIR}/LICENSE"
fi

(
  cd "$TARGET_DIR"
  git init -b main >/dev/null
  git add -A
  git commit -m "chore: init ${PROJECT_NAME}" >/dev/null
)

if [[ "$CREATE_REMOTE" == "true" ]]; then
  require_cmd gh
  (
    cd "$TARGET_DIR"
    if [[ "$VISIBILITY" == "private" ]]; then
      gh repo create "${GITHUB_OWNER}/${PROJECT_NAME}" --private --source=. --remote=origin --push
    else
      gh repo create "${GITHUB_OWNER}/${PROJECT_NAME}" --public --source=. --remote=origin --push
    fi
  )
else
  echo "note: local repo created; remote creation skipped (--no-remote)."
fi

echo
echo "Done."
echo "Next:"
echo "  cd \"${TARGET_DIR}\""
echo "  code .   # if VS Code is installed in WSL"

