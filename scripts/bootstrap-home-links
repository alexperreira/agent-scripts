#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/common.sh
source "${SCRIPT_DIR}/lib/common.sh"

usage() {
  cat <<'EOF'
bootstrap-home-links — ensure home-level symlinks point to this repo

Creates/updates:
  ~/CLAUDE.md            -> <this-repo>/CLAUDE.md
  ~/scripts              -> <this-repo>/scripts
  ~/templates            -> <this-repo>/templates
  ~/.codex/skills/<name> -> <this-repo>/skills/<name>

Claude Code loads the same skills as a plugin rather than by symlink; the
install command is printed at the end of every run.

Default mode is dry-run. Use --apply to make changes.

Usage:
  scripts/bootstrap-home-links [--apply] [--repo <path>] [--no-codex-skills] [--help]

Options:
  --apply             Perform changes (otherwise prints intended actions only)
  --repo              Repo root (default: auto-detect from this script path)
  --no-codex-skills   Skip linking skills into ~/.codex/skills
  --help, -h          Show this help
EOF
}

REPO_ROOT=""
DO_APPLY="false"
DO_CODEX_SKILLS="true"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --apply)
      DO_APPLY="true"; shift ;;
    --repo)
      require_arg_value "$1" "${2:-}"
      REPO_ROOT="${2:-}"; shift 2 ;;
    --no-codex-skills)
      DO_CODEX_SKILLS="false"; shift ;;
    --help|-h)
      usage; exit 0 ;;
    *)
      die "unknown argument: $1" ;;
  esac
done

if [[ -z "$REPO_ROOT" ]]; then
  REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
else
  REPO_ROOT="$(cd "$REPO_ROOT" && pwd)"
fi

[[ -f "${REPO_ROOT}/CLAUDE.md" ]] || die "missing ${REPO_ROOT}/CLAUDE.md"
[[ -d "${REPO_ROOT}/scripts" ]] || die "missing ${REPO_ROOT}/scripts"
[[ -d "${REPO_ROOT}/templates" ]] || die "missing ${REPO_ROOT}/templates"

# link_one <source> <target> — never clobbers a real file or directory.
link_one() {
  local source="$1"
  local target="$2"
  local resolved_source
  resolved_source="$(readlink -f "$source" || true)"

  if [[ -L "$target" ]]; then
    local current
    current="$(readlink -f "$target" || true)"
    # Both sides are fully resolved before comparing. Comparing a resolved
    # target against an unresolved source reports a spurious "would update"
    # whenever the repo path itself traverses a symlink.
    if [[ -n "$resolved_source" && "$current" == "$resolved_source" ]]; then
      echo "ok: $target -> $source"
      return
    fi
    if [[ ! -e "$target" ]]; then
      echo "dangling: $target -> $(readlink "$target")"
    fi
    if [[ "$DO_APPLY" == "true" ]]; then
      ln -sfn "$source" "$target"
      echo "updated: $target -> $source"
    else
      echo "would update: $target -> $source"
    fi
    return
  fi

  if [[ -e "$target" ]]; then
    echo "skip: $target exists and is not a symlink"
    echo "      move it aside manually if you want this script to manage it"
    return
  fi

  if [[ "$DO_APPLY" == "true" ]]; then
    ln -s "$source" "$target"
    echo "created: $target -> $source"
  else
    echo "would create: $target -> $source"
  fi
}

declare -a links=(
  "${HOME}/CLAUDE.md|${REPO_ROOT}/CLAUDE.md"
  "${HOME}/scripts|${REPO_ROOT}/scripts"
  "${HOME}/templates|${REPO_ROOT}/templates"
)

for spec in "${links[@]}"; do
  link_one "${spec##*|}" "${spec%%|*}"
done

# ── Codex skills ───────────────────────────────────────────────────────────────
# Codex has no plugin system, so each skill is linked individually. The skills
# directory is never replaced wholesale — Codex's bundled skills live there too.
SKILLS_SRC="${REPO_ROOT}/skills"

if [[ "$DO_CODEX_SKILLS" == "true" ]]; then
  if [[ ! -d "$SKILLS_SRC" ]]; then
    warn "no skills directory at ${SKILLS_SRC}; skipping Codex skill links"
  elif [[ ! -d "${HOME}/.codex" ]]; then
    echo "skip: ~/.codex not found; Codex not installed?"
  else
    CODEX_SKILLS="${HOME}/.codex/skills"
    if [[ ! -d "$CODEX_SKILLS" ]]; then
      if [[ "$DO_APPLY" == "true" ]]; then
        mkdir -p "$CODEX_SKILLS"
        echo "created: $CODEX_SKILLS"
      else
        echo "would create: $CODEX_SKILLS"
      fi
    fi

    for skill_dir in "${SKILLS_SRC}"/*/; do
      [[ -d "$skill_dir" ]] || continue
      skill_name="$(basename "$skill_dir")"
      link_one "${SKILLS_SRC}/${skill_name}" "${CODEX_SKILLS}/${skill_name}"
    done
  fi
fi

# ── Legacy links ───────────────────────────────────────────────────────────────
# ~/AGENTS.md was managed before AGENTS.md was folded into CLAUDE.md. This script
# no longer creates it; report it rather than deleting anything.
LEGACY="${HOME}/AGENTS.md"
if [[ -L "$LEGACY" ]]; then
  legacy_target="$(readlink "$LEGACY")"
  if [[ "$legacy_target" == "${REPO_ROOT}/"* && ! -e "$LEGACY" ]]; then
    echo
    warn "${LEGACY} is a dangling symlink to a file this repo no longer has."
    warn "It is no longer managed here. Remove it with: trash-put ${LEGACY}"
  fi
fi

if [[ "$DO_APPLY" != "true" ]]; then
  echo
  echo "(dry-run; re-run with --apply to make these changes)"
fi

cat <<EOF

Claude Code loads this repo's skills as a plugin, not via symlink:
  /plugin marketplace add ${REPO_ROOT}
  /plugin install flow@agent-scripts
EOF
